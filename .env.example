# ========== 环境变量模板 ==========
# 复制此文件为 .env.local 并填入实际值

# Cron 任务密钥（防止定时接口被随意调用）
# 在 Vercel 控制台中设置，值可以是任意随机字符串
CRON_SECRET=your-random-secret-string-here

# Anthropic API Key（用于 Claude AI 生成每日市场分析）
# 在 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=sk-ant-xxx

# Finnhub API Key（用于获取美股实时行情 + 新闻）
# 在 https://finnhub.io/ 免费注册获取
FINNHUB_API_KEY=your-finnhub-api-key

# CoinMarketCap API Key（用于获取加密恐惧贪婪指数）
# 在 https://coinmarketcap.com/api/ 免费注册获取
CMC_API_KEY=your-cmc-api-key

# CoinGlass API Key（用于获取 BTC 链上指标：SOPR、LTH Supply、200WMA）
# 在 https://www.coinglass.com/pricing 获取（最低 $29/月 Hobbyist 套餐）
COINGLASS_API_KEY=your-coinglass-api-key

# OpenAI API Key（用于 TTS 语音合成，将每日早报转为音频）
# 在 https://platform.openai.com/ 获取
# 可选：不设置则跳过音频生成
OPENAI_API_KEY=sk-xxx

# Vercel Blob 存储（用于存储 TTS 音频文件）
# 在 Vercel 控制台 → Storage → Create Blob Store 后自动设置
BLOB_READ_WRITE_TOKEN=vercel_blob_xxx

# Upstash Redis 连接（在 Vercel Marketplace 安装 Upstash Redis 集成后自动设置）
# 也可以在 https://console.upstash.com/ 手动创建数据库后填入
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx
